# --- R session / credentials ---
.Rproj.user/
.Rhistory
.RData
.Ruserdata
.Renviron
.env
.DS_Store

# --- Claude Code local state ---
.claude/settings.local.json
.claude/agent-memory/
.claude/scheduled_tasks.lock
CLAUDE.local.md

# --- renv (library managed by renv after init; lock + settings are tracked) ---
renv/library/
renv/local/
renv/cellar/
renv/lock
renv/python/
renv/sandbox/
renv/staging/

# --- targets cache ---
_targets/

# --- Quarto artefacts (regenerate from .qmd) ---
notes/*.html
notes/*_files/
notes/*.knit.md
paper/*.html
paper/*_files/
.quarto/
**/*.quarto_ipynb

# --- data: ignore contents, but keep tracked scaffolding + example ---
# NOTE: order matters. Re-include the directory itself before its contents.
data-raw/**
!data-raw/
!data-raw/.gitkeep
!data-raw/README.md
!data-raw/PROVENANCE.md
!data-raw/example/
!data-raw/example/**
data/**
!data/
!data/.gitkeep

# --- prompt logs: local process artifacts, not versioned by default ---
# Keep the directory scaffolding + README, but do not track the per-session
# logs. This also stops "Use this template" from copying the template's own
# development logs into new projects. To version your logs, remove these lines.
prompts/*.md
!prompts/README.md

# --- spatial data (uncomment if the project handles GIS files) ---
# *.shp
# *.shx
# *.dbf
# *.prj
# *.cpg
# *.zip
